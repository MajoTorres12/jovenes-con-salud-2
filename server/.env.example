# Jóvenes con Salud — Environment Variables
# Copy this file to .env and fill in the values

# ========================================
# Server
# ========================================
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ========================================
# Database (PostgreSQL)
# ========================================
# Option A: Individual variables (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jovenes_con_salud_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Option B: Connection string (cloud — Neon, Supabase, Railway)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_SSL=true

# ========================================
# Authentication (JWT)
# ========================================
JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_EXPIRES_IN=7d

# ========================================
# Email (Nodemailer) — Opcional para inicio
# ========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-app-password
