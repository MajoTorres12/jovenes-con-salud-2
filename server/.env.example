# Jóvenes con Salud — Environment Variables
# Copy this file to .env and fill in the values

# ========================================
# Server
# ========================================
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ========================================
# Database (PostgreSQL)
# ========================================
# Option A: Individual variables (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jovenes_con_salud_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Option B: Connection string (cloud — Neon, Supabase, Railway)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_SSL=true

# ========================================
# Authentication (JWT)
# ========================================
JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_EXPIRES_IN=7d

# ========================================
# Email (Nodemailer) — Opcional para inicio
# ========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-app-password

# ========================================
# Firebase (Push Notifications)
# ========================================
# 1. Ve a Firebase Console → Configuración del proyecto → Cuentas de servicio
# 2. Genera una nueva clave privada (JSON)
# 3. Copia los valores aquí:
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

